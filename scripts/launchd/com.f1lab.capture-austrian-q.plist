<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.f1lab.capture-austrian-q</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/ysoh/Projects/f1-polymarket-lab/scripts/capture_austrian_2026.sh</string>
    <string>-202600823</string>
    <string>90</string>
    <string>20</string>
  </array>
  <!-- 2026-06-27 21:00 KST (= 12:00 UTC). capture-live-weekend then waits to the
       (Q 14:00 UTC - 90m = 12:30 UTC) window and streams to ~14:20 UTC. -->
