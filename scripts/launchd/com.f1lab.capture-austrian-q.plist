  <dict>
    <key>Month</key><integer>6</integer>
    <key>Day</key><integer>27</integer>
    <key>Hour</key><integer>21</integer>
    <key>Minute</key><integer>0</integer>
  </dict>
  <key>RunAtLoad</key>
  <false/>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
  <key>StandardOutPath</key>
  <string>/Users/ysoh/Projects/f1-polymarket-lab/data/reports/operations/austrian-2026-capture/launchd-q.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/ysoh/Projects/f1-polymarket-lab/data/reports/operations/austrian-2026-capture/launchd-q.err.log</string>
</dict>
</plist>
